# ── Copy this file to .env and fill in your values ────────────────────────────

# ── LLM (required) ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Override to use a different OpenAI-compatible endpoint (e.g. Blablador, Ollama)
OPENAI_BASE_URL=https://api.openai.com/v1

# Model used for Modes 1 & 2 (text-only)
DEFAULT_MODEL=gpt-4o-mini
# Model used for Mode 3 (vision-language)
VISION_MODEL=gpt-4o

# ── Mode 2: Browserbase MCP fallback (optional) ─────────────────────────────────
BROWSERBASE_API_KEY=

# ── Parallelism ─────────────────────────────────────────────────────────────────
# Max concurrent Playwright sessions (Mode 2 primary)
MAX_BROWSER_SESSIONS=8
# OASIS async semaphore (Modes 1 & 3)
OASIS_SEMAPHORE=64

# ── Server ──────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=7860
RELOAD=false
