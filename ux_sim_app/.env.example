# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Optional: model overrides ──────────────────────────────────────────────────
# DEFAULT_MODEL is used for text/persona generation (fast, cheap)
# VISION_MODEL is used for AI redesigns and visual analysis (must support vision)
DEFAULT_MODEL=gpt-4o-mini
VISION_MODEL=gpt-4o

# ── Optional: Mode 2 Browserbase fallback ─────────────────────────────────────
# Only needed if Playwright fails during browser-action simulation
BROWSERBASE_API_KEY=bb_live_...

# ── Optional: Email delivery ───────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@gmail.com

# ── Optional: Performance tuning ──────────────────────────────────────────────
MAX_BROWSER_SESSIONS=3
OASIS_SEMAPHORE=10
